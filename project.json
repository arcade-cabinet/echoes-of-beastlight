{
  "name": "game",
  "$schema": "node_modules/nx/schemas/project-schema.json",
  "sourceRoot": "src",
  "projectType": "application",
  "targets": {
    "build": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "commands": ["cargo build --release"],
        "cwd": "."
      },
      "configurations": {
        "production": {
          "commands": ["cargo build --release --target wasm32-unknown-unknown", "./build-web.sh"]
        }
      }
    },
    "serve": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "commands": ["cargo run"]
      }
    },
    "test": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "commands": ["cargo test"]
      }
    },
    "lint": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "commands": ["cargo clippy -- -D warnings"]
      }
    },
    "format": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "commands": ["cargo fmt"]
      }
    },
    "format:check": {
      "executor": "@nrwl/workspace:run-commands",
      "options": {
        "commands": ["cargo fmt -- --check"]
      }
    }
  }
}
