{
  "tasks": [
    {
      "type": "shell",
      "command": "cargo check",
      "cwd": "${workspaceFolder}",
      "runOn": "folderOpen",
      "name": "Validate Rust Code"
    },
    {
      "type": "shell",
      "command": "cargo clippy -- -W clippy::all",
      "cwd": "${workspaceFolder}",
      "runOn": "save",
      "name": "Run Clippy Linter"
    },
    {
      "type": "shell",
      "command": "cargo fmt",
      "cwd": "${workspaceFolder}",
      "runOn": "save",
      "name": "Format Rust Code"
    },
    {
      "type": "shell",
      "command": "python3 -c \"import yaml; yaml.safe_load(open('game-config.yaml'))\"",
      "cwd": "${workspaceFolder}",
      "runOn": "save",
      "name": "Validate Game Config"
    },
    {
      "type": "shell",
      "command": "find assets -name '*.yaml' -o -name '*.yml' | xargs -I {} python3 -c \"import yaml; yaml.safe_load(open('{}'))\"",
      "cwd": "${workspaceFolder}",
      "runOn": "save",
      "name": "Validate YAML Assets"
    }
  ],
  "environment": {
    "RUST_BACKTRACE": "1",
    "CARGO_TERM_COLOR": "always",
    "BEVY_ASSET_PATH": "./assets",
    "GAME_CONFIG_PATH": "./game-config.yaml"
  },
  "setupCommands": [
    "rustup target add wasm32-unknown-unknown",
    "cargo install wasm-bindgen-cli",
    "cargo install cargo-watch",
    "npm install -g http-server"
  ],
  "watchPatterns": [
    "game-config.yaml",
    "src/**/*.rs",
    "assets/**/*.yaml",
    "assets/**/*.yol"
  ],
  "autoFix": {
    "rustFormat": true,
    "yamlValidation": true,
    "removeUnusedImports": true
  },
  "backgroundTasks": [
    {
      "name": "Monitor Config Changes",
      "description": "Detect changes to game-config.yaml and suggest regeneration",
      "trigger": "fileChange",
      "pattern": "game-config.yaml",
      "action": "suggest",
      "message": "Game config changed. Would you like to regenerate affected assets?"
    },
    {
      "name": "Asset Validation",
      "description": "Continuously validate generated assets",
      "interval": 300,
      "command": "node tools/validate-assets.js"
    },
    {
      "name": "Build Health Check",
      "description": "Ensure both native and WASM builds work",
      "interval": 600,
      "commands": [
        "cargo check",
        "cargo check --target wasm32-unknown-unknown"
      ]
    }
  ]
}