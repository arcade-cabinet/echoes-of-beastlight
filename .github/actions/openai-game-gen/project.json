{
  "name": "openai-action",
  "$schema": "../../../node_modules/nx/schemas/project-schema.json",
  "sourceRoot": ".github/actions/openai-game-gen/src",
  "projectType": "library",
  "targets": {
    "build": {
      "executor": "@nrwl/js:tsc",
      "options": {
        "outputPath": ".github/actions/openai-game-gen/dist",
        "main": ".github/actions/openai-game-gen/src/index.ts",
        "tsConfig": ".github/actions/openai-game-gen/tsconfig.json"
      }
    },
    "lint": {
      "executor": "@nrwl/linter:eslint",
      "options": {
        "lintFilePatterns": [".github/actions/openai-game-gen/**/*.ts"]
      }
    },
    "test": {
      "executor": "@nrwl/jest:jest",
      "options": {
        "jestConfig": ".github/actions/openai-game-gen/jest.config.js",
        "passWithNoTests": true
      }
    }
  }
}
