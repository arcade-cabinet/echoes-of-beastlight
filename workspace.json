{
  "version": 2,
  "projects": {
    "game": {
      "root": ".",
      "sourceRoot": "src",
      "projectType": "application",
      "targets": {
        "build": {
          "executor": "@nrwl/workspace:run-commands",
          "options": {
            "commands": [
              "cargo build --release"
            ],
            "cwd": "."
          },
          "configurations": {
            "production": {
              "commands": [
                "cargo build --release --target wasm32-unknown-unknown",
                "./build-web.sh"
              ]
            }
          }
        },
        "serve": {
          "executor": "@nrwl/workspace:run-commands",
          "options": {
            "commands": [
              "cargo run"
            ]
          }
        },
        "test": {
          "executor": "@nrwl/workspace:run-commands",
          "options": {
            "commands": [
              "cargo test"
            ]
          }
        },
        "lint": {
          "executor": "@nrwl/workspace:run-commands",
          "options": {
            "commands": [
              "cargo clippy -- -D warnings"
            ]
          }
        },
        "format": {
          "executor": "@nrwl/workspace:run-commands",
          "options": {
            "commands": [
              "cargo fmt"
            ]
          }
        },
        "format:check": {
          "executor": "@nrwl/workspace:run-commands",
          "options": {
            "commands": [
              "cargo fmt -- --check"
            ]
          }
        }
      }
    },
    "openai-action": {
      "root": ".github/actions/openai-game-gen",
      "sourceRoot": ".github/actions/openai-game-gen/src",
      "projectType": "library",
      "targets": {
        "build": {
          "executor": "@nrwl/js:tsc",
          "options": {
            "outputPath": ".github/actions/openai-game-gen/dist",
            "main": ".github/actions/openai-game-gen/src/index.ts",
            "tsConfig": ".github/actions/openai-game-gen/tsconfig.json"
          }
        },
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": [".github/actions/openai-game-gen/**/*.ts"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "options": {
            "jestConfig": ".github/actions/openai-game-gen/jest.config.js",
            "passWithNoTests": true
          }
        }
      }
    },
    "tools": {
      "root": "tools",
      "sourceRoot": "tools",
      "projectType": "library",
      "targets": {
        "lint": {
          "executor": "@nrwl/linter:eslint",
          "options": {
            "lintFilePatterns": ["tools/**/*.js"]
          }
        },
        "test": {
          "executor": "@nrwl/jest:jest",
          "options": {
            "jestConfig": "tools/jest.config.js",
            "passWithNoTests": true
          }
        },
        "validate-assets": {
          "executor": "@nrwl/workspace:run-commands",
          "options": {
            "commands": [
              "node tools/validate-assets.js"
            ]
          }
        }
      }
    },
    "e2e": {
      "root": "e2e",
      "sourceRoot": "e2e/src",
      "projectType": "application",
      "targets": {
        "e2e": {
          "executor": "@nrwl/workspace:run-commands",
          "options": {
            "commands": [
              "echo 'E2E tests would run here'"
            ]
          }
        }
      }
    }
  }
}