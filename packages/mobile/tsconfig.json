{
	"extends": "../../tsconfig.json",
	"compilerOptions": {
		"jsx": "react-native",
		"lib": ["ES2022", "DOM"],
		"noEmit": true,
		"strict": true,
		"baseUrl": ".",
		"paths": {
			"@/*": ["./*"],
			"@game-core/*": ["../game-core/*"]
		}
	},
	"include": ["**/*.ts", "**/*.tsx"],
	"exclude": ["node_modules", "dist", ".expo", "android", "ios"]
}
